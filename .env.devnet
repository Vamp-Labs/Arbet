# Arbet Devnet Deployment Environment Configuration
# Use this for Devnet deployments

# ===== Solana RPC Configuration =====
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet
SOLANA_DEVNET_RPC=https://api.devnet.solana.com

# ===== API Keys (Configure for Devnet) =====
ALCHEMY_API_KEY=B3ZR8idizuxRWbEmxLKrkx9XhM57T_BM
HELIUS_API_KEY=your_helius_devnet_key_here
JITO_API_URL=https://api.devnet.jito.wtf
JITO_AUTH_TOKEN=your_jito_devnet_token_here

# ===== Frontend Configuration =====
NEXT_PUBLIC_RPC_ENDPOINT=https://api.devnet.solana.com
NEXT_PUBLIC_NETWORK=devnet
NEXT_PUBLIC_API_URL=${API_ENDPOINT:-http://localhost:8000}

# ===== Backend Configuration =====
API_PORT=8000
API_ENDPOINT=http://localhost:8000
DEBUG=false
PYTHONUNBUFFERED=1

# ===== Database Configuration (Managed) =====
DATABASE_URL=postgresql://arbet:${DB_PASSWORD}@postgres-devnet:5432/arbet_devnet
REDIS_URL=redis://redis-devnet:6379

# ===== CORS Configuration =====
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://arbet-devnet.example.com

# ===== Smart Contract Configuration =====
ANCHOR_PROVIDER_URL=https://api.devnet.solana.com
PROGRAM_ID=your_deployed_program_id_here
AGENT_WALLET_PUBKEY=your_agent_wallet_pubkey_here
AGENT_WALLET_PRIVATE_KEY=${AGENT_PRIVATE_KEY}

# ===== Market APIs =====
CAPITOLA_API_URL=https://api.capitola.io
CAPITOLA_API_KEY=your_capitola_devnet_key_here
POLYMARKET_API_URL=https://api.polymarket.com
HEDGEHOG_API_URL=https://api.hedgehog.trade

# ===== LLM Configuration (Ollama) =====
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen:3b

# ===== Logging Configuration =====
LOG_LEVEL=INFO
LOG_FORMAT=json

# ===== Monitoring & Metrics =====
ENABLE_METRICS=true
METRICS_PORT=9090

# ===== Email Configuration =====
SMTP_HOST=mailhog-devnet
SMTP_PORT=1025
SMTP_USER=noreply@arbet-devnet.local
SMTP_PASSWORD=password

# ===== Deployment Specific =====
DEPLOYMENT_ENV=devnet
DEPLOYMENT_DATE=${DEPLOYMENT_DATE}
DEPLOYMENT_VERSION=${VERSION:-latest}
