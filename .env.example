.env.example

# Solana RPC
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

# Helius API (free tier)
HELIUS_API_KEY=your_helius_api_key_here

# Alchemy API
ALCHEMY_API_KEY=B3ZR8idizuxRWbEmxLKrkx9XhM57T_BM

# Jito Bundle API
JITO_API_URL=https://api.devnet.jito.wtf
JITO_AUTH_TOKEN=your_jito_token_here

# Ollama LLM
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen:3b

# Frontend
NEXT_PUBLIC_RPC_ENDPOINT=https://api.devnet.solana.com
NEXT_PUBLIC_NETWORK=devnet
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend
API_PORT=8000
DATABASE_URL=sqlite:///./arbet.db
CORS_ORIGINS=http://localhost:3000,https://arbet-agents.vercel.app

# Smart Contract
ANCHOR_PROVIDER_URL=https://api.devnet.solana.com
PROGRAM_ID=your_program_id_here

# Market APIs
CAPITOLA_API_URL=https://api.capitola.io
CAPITOLA_API_KEY=your_capitola_key_here
POLYMARKET_API_URL=https://api.polymarket.com
HEDGEHOG_API_URL=https://api.hedgehog.trade

# Logging
LOG_LEVEL=INFO
